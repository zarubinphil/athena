<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Athena — ежедневный launchd status=127 guard. $HOME подставляется Слоем 5 bootstrap (sed).
     Сам guard зависит только от системных бинарей (PlistBuddy/plutil по абс. пути) — PATH базовый. -->
<plist version="1.0">
<dict>
  <key>Label</key><string>com.athena.launchd-guard</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>$HOME/.claude/scripts/launchd-127-guard.sh</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>9</integer><key>Minute</key><integer>30</integer></dict>
  <key>StandardOutPath</key><string>$HOME/.claude/health.log</string>
  <key>StandardErrorPath</key><string>$HOME/.claude/health.log</string>
</dict>
</plist>
