{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read({{ .chezmoi.homeDir }}/.claude/secrets/**)",
      "Read({{ .chezmoi.homeDir }}/.claude/server.env)",
      "Read({{ .chezmoi.homeDir }}/.claude/session-env/**)",
      "Read({{ .chezmoi.homeDir }}/.ssh/**)",
      "Read({{ .chezmoi.homeDir }}/.secrets/**)",
      "Read({{ .chezmoi.homeDir }}/.config/gh/**)",
      "Read({{ .chezmoi.homeDir }}/.git-credentials)",
      "Read({{ .chezmoi.homeDir }}/.claude/mcp.json)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/id_rsa*)",
      "Read(**/*.pem)",
      "Read(**/.scrapegraphai/**)",
      "Read(**/references/secrets-map.md)",
      "Edit(**/.env)",
      "Write(**/.env)",
      "Edit(**/*secret*)",
      "Write(**/*secret*)",
      "Write({{ .chezmoi.homeDir }}/.ssh/**)",
      "Edit({{ .chezmoi.homeDir }}/.ssh/**)",
      "Write({{ .chezmoi.homeDir }}/.secrets/**)",
      "Edit({{ .chezmoi.homeDir }}/.secrets/**)",
      "Write({{ .chezmoi.homeDir }}/.git-credentials)",
      "Edit({{ .chezmoi.homeDir }}/.git-credentials)",
      "Write({{ .chezmoi.homeDir }}/.claude/mcp.json)",
      "Edit({{ .chezmoi.homeDir }}/.claude/mcp.json)",
      "Write(**/*.pem)",
      "Edit(**/*.pem)",
      "Write(**/*.key)",
      "Edit(**/*.key)",
      "Write(**/*.ovpn)",
      "Edit(**/*.ovpn)",
      "Write(**/*credential*)",
      "Edit(**/*credential*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"{{ .chezmoi.homeDir }}/.claude/hooks/security-guard.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"{{ .chezmoi.homeDir }}/.claude/hooks/bash-guard.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"{{ .chezmoi.homeDir }}/.claude/hooks/git-leak-guard.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{ .chezmoi.homeDir }}/.claude/hooks/skill-router.mjs\"",
            "timeout": 6,
            "statusMessage": "GraphiFy skill routing..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"{{ .chezmoi.homeDir }}/.claude/hooks/onboarding-detect.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"{{ .chezmoi.homeDir }}/.claude/scripts/session-token-log.sh\"",
            "async": true,
            "timeout": 20,
            "statusMessage": "Token-spend → self-learning..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@superpowers-dev": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "caveman@caveman": true
  }
}
