# Athena OS — chezmoi data (generic дефолты).
# Копировать → .chezmoidata.yaml (gitignored), заполнить под машину.
# Личные значения (vps_host и т.п.) — приватный слой Фазы 4, НЕ в публичный source.

# Путь к node для хуков. Apple Silicon (Homebrew): /opt/homebrew/bin/node
node_bin: /usr/local/bin/node

athena:
  # Зеркало capability на VPS (личное, Фаза 4). Пусто = выключено.
  # Формат: user@host:/path/to/agent-os
  vps_host: ""
